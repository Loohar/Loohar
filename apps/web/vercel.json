{
  "redirects": [
    {
      "source": "/sites/:slug",
      "destination": "/:slug",
      "permanent": true
    },
    {
      "source": "/sites/:slug/:path*",
      "destination": "/:slug/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://loohar-api.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://loohar-api.onrender.com/health"
    },
    {
      "source": "/:slug/sitemap.xml",
      "destination": "https://loohar-api.onrender.com/api/public/restaurants/:slug/sitemap.xml"
    },
    {
      "source": "/:slug/robots.txt",
      "destination": "https://loohar-api.onrender.com/api/public/restaurants/:slug/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
