NODE_ENV=production
PORT=10000

# Database
# Runtime API traffic should use the Supabase transaction pooler with a small pool.
# Example shape only:
# postgresql://USER:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=20
DATABASE_URL=
# Prisma Migrate should use the Supabase direct connection. Keep this backend-only.
# Example shape only:
# postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DIRECT_URL=

# Auth
JWT_SECRET=
REFRESH_TOKEN_SECRET=
ENABLE_DEMO_LOGIN=false

# Public URLs
APP_URL=https://loohar.com
API_URL=https://loohar.com/api
ADMIN_URL=https://loohar.com/admin
PLATFORM_URL=https://loohar.com
TENANT_ROOT_DOMAIN=loohar.com
PUBLIC_SITE_FALLBACK_URL=https://loohar.com
PUBLIC_SITE_URL=https://loohar.com
DRIVER_APP_URL=https://driver.loohar.com
TENANT_CNAME_TARGET=cname.vercel-dns.com
MOBILE_DEEP_LINK_SCHEME=loohar
DRIVER_DEEP_LINK_SCHEME=loohar-driver
ORDER_TRACKING_TOKEN_DAYS=30

# CORS
CORS_ORIGINS=https://loohar.com,https://www.loohar.com,https://admin.loohar.com,https://app.loohar.com,https://driver.loohar.com
ALLOW_LOCAL_CORS=false
ALLOW_TENANT_SUBDOMAIN_CORS=true

# Platform branding
PLATFORM_NAME=Loohar
PLATFORM_DOMAIN=loohar.com
SUPPORT_EMAIL=support@loohar.com

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM="Loohar Security Team <noreply@loohar.com>"
EMAIL_REPLY_TO=support@loohar.com
EMAIL_LOGO_URL=https://loohar.com/logo.png
RESET_PASSWORD_EXPIRES_MINUTES=30
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# SMS
SMS_PROVIDER=console
SMS_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Financial separation
# Loohar SaaS subscriptions. Loohar is the merchant of record for these charges.
STRIPE_PLATFORM_SECRET_KEY=
STRIPE_PLATFORM_PUBLIC_KEY=
STRIPE_PLATFORM_WEBHOOK_SECRET=
STRIPE_PLATFORM_PRICE_STARTER=
STRIPE_PLATFORM_PRICE_PROFESSIONAL=
STRIPE_PLATFORM_PRICE_ENTERPRISE=
PLATFORM_PLAN_STARTER_CENTS=9900
PLATFORM_PLAN_PROFESSIONAL_CENTS=19900
PLATFORM_PLAN_ENTERPRISE_CENTS=39900
PLATFORM_BILLING_SUCCESS_URL=https://loohar.com/register/success?session_id={CHECKOUT_SESSION_ID}
PLATFORM_BILLING_CANCEL_URL=https://loohar.com/register?billing=cancelled
PLATFORM_BILLING_PORTAL_RETURN_URL=https://loohar.com/restaurant/settings/payments
PLATFORM_BILLING_TRIAL_DAYS=0

# Restaurant customer order payments. Restaurants are the merchants of record.
# Use Stripe Connect Express hosted onboarding. Never expose this secret to apps/web.
STRIPE_CONNECT_SECRET_KEY=
STRIPE_CONNECT_PUBLIC_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_COUNTRY=US
STRIPE_CONNECT_REFRESH_URL=https://loohar.com/restaurant/settings/payments?connect=refresh
STRIPE_CONNECT_RETURN_URL=https://loohar.com/restaurant/settings/payments?connect=return
ORDER_PAYMENT_CURRENCY=usd
ORDER_PAYMENT_PLATFORM_FEE_BPS=0
ORDER_PAYMENT_PLATFORM_FEE_FIXED_CENTS=0

# Order quote/tax foundation. Replace manual tax with a certified tax provider before broad production payments.
DEFAULT_TAX_RATE_BPS=825
TAX_PROVIDER=manual
TAXJAR_API_KEY=
AVALARA_ACCOUNT_ID=
AVALARA_LICENSE_KEY=

# Authorize.Net is intentionally disabled until sandbox certification passes.
AUTHORIZE_NET_ENABLED=false
AUTHORIZE_NET_PLATFORM_ENABLED=false
AUTHORIZE_NET_ORDERS_ENABLED=false
AUTHORIZE_NET_PLATFORM_API_LOGIN_ID=
AUTHORIZE_NET_PLATFORM_TRANSACTION_KEY=
AUTHORIZE_NET_PLATFORM_SIGNATURE_KEY=
AUTHORIZE_NET_ORDERS_API_LOGIN_ID=
AUTHORIZE_NET_ORDERS_TRANSACTION_KEY=
AUTHORIZE_NET_ORDERS_SIGNATURE_KEY=

# Legacy order checkout variables. Keep empty for new deployments.
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_CURRENCY=usd

# Storage
STORAGE_PROVIDER=supabase_storage
STORAGE_BUCKET=loohar-uploads
SUPABASE_STORAGE_BUCKET=loohar-uploads
SUPABASE_STORAGE_PUBLIC_BASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_SYNC_ENABLED=true
SUPABASE_AUTH_SYNC_REQUIRED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
