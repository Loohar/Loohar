  order             Order?     @relation(fields: [orderId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([restaurantId])
  @@index([driverId])
  @@index([orderId])
}

model DeliveryFeeRule {
  id                String     @id @default(cuid())
  restaurantId      String
