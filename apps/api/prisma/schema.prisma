  orderPayment          RestaurantOrderPayment? @relation(fields: [orderPaymentId], references: [id])
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([restaurantId])
  @@index([orderPaymentId])
}

model RestaurantPayout {
  id                String          @id @default(cuid())
  restaurantId      String
  provider          PaymentProvider @default(STRIPE_CONNECT)
  providerPayoutId  String?         @unique
