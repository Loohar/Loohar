  restaurant            Restaurant              @relation(fields: [restaurantId], references: [id])
  orderPayment          RestaurantOrderPayment  @relation(fields: [orderPaymentId], references: [id])
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([restaurantId])
  @@index([orderPaymentId])
  @@index([providerRefundId])
}

model RestaurantPaymentDispute {
  id                    String                 @id @default(cuid())
  restaurantId          String
  orderPaymentId        String?
  provider              PaymentProvider        @default(STRIPE_CONNECT)
  providerDisputeId     String?                @unique
