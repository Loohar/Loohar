{
  "name": "restaurant-saas-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/api run lint && npm --workspace apps/web run lint",
    "security:scan": "node scripts/security-scan.mjs",
    "storage:check": "node scripts/storage-check.mjs",
    "storage:probe": "node scripts/storage-probe.mjs",
    "upload:probe": "node scripts/upload-endpoint-probe.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "smoke:production": "node scripts/production-smoke-test.mjs",
    "auth:audit": "npm --workspace apps/api run auth:audit",
    "bootstrap:admin": "npm --workspace apps/api run bootstrap:admin",
    "auth:repair-owner": "npm --workspace apps/api run auth:repair-owner",
    "prisma:generate": "npm --workspace apps/api run prisma:generate",
    "prisma:migrate": "npm --workspace apps/api run prisma:migrate",
    "prisma:deploy": "npm --workspace apps/api run prisma:deploy",
    "prisma:deploy:safe": "npm --workspace apps/api run prisma:deploy:safe",
    "seed": "npm --workspace apps/api run seed",
    "prisma:seed": "npm --workspace apps/api run prisma:seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
